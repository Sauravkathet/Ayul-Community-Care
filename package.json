{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*"
  ],
  "scripts": {
    "dev": "bash ./scripts/dev.sh",
    "dev:api": "npm run dev --workspace @workspace/api-server",
    "dev:client": "npm run dev --workspace @workspace/ayul-community-care",
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
